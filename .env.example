# Copy to .env and fill in real values. Every variable has a safe
# synthetic-data fallback (see config.py) so the app runs without any
# of these being set.

ENV=development
DEBUG=true
SECRET_KEY=change_me_in_production

# --- Database ---
# Local dev default (SQLite) needs no changes. For production:
# DATABASE_URL=postgresql+psycopg2://user:pass@host:5432/kwid
DATABASE_URL=sqlite:///data/processed/kwid.db
USE_POSTGIS=false

# --- Mapping ---
MAPBOX_TOKEN=

# --- Module 3 API connectors ---
WRA_API=
WRA_API_BASE_URL=https://wra.go.ke/api
WASREB_API=
WASREB_API_BASE_URL=https://wasreb.go.ke/api
AQUASTAT_BASE_URL=https://data.apps.fao.org/aquastat/api/v1
NASA_API=
NASA_POWER_BASE_URL=https://power.larc.nasa.gov/api/temporal/daily/point
# CHIRPS rainfall is sourced from Google Earth Engine (api/chirps.py).
# Configure ONE of the two auth paths below; leave blank to use the
# synthetic fallback.
GEE_SERVICE_ACCOUNT_EMAIL=
GEE_SERVICE_ACCOUNT_KEY_FILE=
GEE_PROJECT_ID=
OSM_OVERPASS_URL=https://overpass-api.de/api/interpreter
WORLDPOP_BASE_URL=https://www.worldpop.org/rest/data
KENYA_OPEN_DATA_BASE_URL=https://kenya.opendataforafrica.org/api
COPERNICUS_API_KEY=
COPERNICUS_BASE_URL=https://cds.climate.copernicus.eu/api/v2

HTTP_TIMEOUT_SECONDS=15
HTTP_MAX_RETRIES=3
ALLOW_SYNTHETIC_FALLBACK=true
LOG_LEVEL=INFO
